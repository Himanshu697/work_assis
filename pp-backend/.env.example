# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local: postgresql://postgres:yourpassword@localhost:5432/projectly
# Railway: automatically provided as DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/projectly

# JWT Secret - change this to any random long string
JWT_SECRET=change_this_to_a_random_secret_key_123

# Port (Railway sets this automatically)
PORT=5000

# Set to "production" when deploying
NODE_ENV=development
